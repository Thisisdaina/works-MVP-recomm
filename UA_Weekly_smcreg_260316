, naver_week AS (
    SELECT a.`Week`
        , Impr
        , Click
        , Cost
    FROM (SELECT DATE(DATE_TRUNC(TIMESTAMP(PARSE_DATE('%Y.%m.%d.', json_extract_scalar(json_data, '$.date'))), week(monday))) `Week`
        , SUM(CAST(json_extract_scalar(json_data, '$.impression') AS FLOAT64)) Impr
        , SUM(CAST(json_extract_scalar(json_data, '$.click') AS FLOAT64)) Click
    FROM `local-now-763.ua_marketing.tb_naver`

    WHERE 1=1
    AND json_extract_scalar(json_data, '$.campaign_name') = '1.BS_M'

    GROUP BY 1) a

    LEFT JOIN (
    SELECT DATE(DATE_TRUNC(TIMESTAMP(day), week(monday))) `Week`
        , SUM(CAST(CASE WHEN day <= '2025-01-14' THEN 56667 ELSE 26667 END AS NUMERIC)) Cost
    FROM( SELECT day FROM UNNEST(GENERATE_DATE_ARRAY('2024-12-30', CURRENT_DATE(), INTERVAL 1 DAY)) AS day)
    GROUP BY 1) b
    ON a.`Week` = b.`Week`
)

, naver_adj AS (
    SELECT a.`Week`
        , CAST(b.Impr AS numeric) Impr
        , CAST(b.Click AS numeric) as Click
        , CAST(Cost AS NUMERIC) as Cost
        , CAST(a.installs AS numeric) installs
        , CAST(a.daus AS numeric) daus
        , CAST(a.waus AS numeric) waus
        , CAST(a.maus AS numeric)maus
        , CAST(a.Contact  AS numeric) as Contact
        , CAST(a.DB AS numeric) as DB
    FROM (SELECT DATE(DATE_TRUNC(TIMESTAMP(JSON_EXTRACT_SCALAR(json_data, '$.day')), week(monday))) `Week`
            , SUM(CAST(json_extract_scalar(json_data, '$.installs') AS NUMERIC)) installs
            , SUM(CAST(json_extract_scalar(json_data, '$.daus') AS NUMERIC)) daus
            , SUM(CAST(json_extract_scalar(json_data, '$.waus') AS NUMERIC)) waus
            , SUM(CAST(json_extract_scalar(json_data, '$.maus') AS NUMERIC)) maus
            , SUM(CAST(json_extract_scalar(json_data, '$.pur_car_call_clk_t_events') AS NUMERIC)) +
            SUM(CAST(json_extract_scalar(json_data, '$.purchased_common_contact_ask_complete_events') AS NUMERIC)) AS Contact
            , SUM(CAST(json_extract_scalar(json_data, "$['smc_regist_complete (total)_events']") AS NUMERIC)) +
              SUM(CAST(json_extract_scalar(json_data, "$['smc_reg_complete (total)_events']") AS NUMERIC)) +
            SUM(CAST(json_extract_scalar(json_data, "$['smc_re-reg_complete (total)_events']") AS NUMERIC)) AS DB

    FROM `local-now-763.ua_marketing.tb_adjust`

    WHERE json_extract_scalar(json_data, '$.channel') = 'Naver_SA_Brand'
    GROUP BY 1) a

    LEFT JOIN naver_week b
    ON a.`Week` = b.`Week`
)

