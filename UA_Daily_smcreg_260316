          SUM(CAST(json_extract_scalar(json_data, "$['smc_reg_complete (total)_events']") AS NUMERIC)) +
          SUM(CAST(json_extract_scalar(json_data, "$['smc_re-reg_complete (total)_events']") AS NUMERIC)) AS DB
    FROM `local-now-763.ua_marketing.tb_adjust`
    WHERE json_extract_scalar(json_data, '$.channel') = 'Facebook'
    GROUP BY 1) a

    LEFT JOIN (
      SELECT CAST(JSON_EXTRACT_SCALAR(json_data, '$.date_stop')AS STRING) `Date`
        , SUM(CAST(json_extract_scalar(json_data, '$.impressions') AS NUMERIC)) Impr
        , SUM(CAST(json_extract_scalar(json_data, '$.spend') AS NUMERIC)) spend
        , SUM(CAST(json_extract_scalar(json_data, '$.clicks') AS NUMERIC)) Click
      FROM `local-now-763.ua_marketing.tb_meta`
      GROUP BY 1
    ) b

   ON a.`Date` = b.`Date`
)


