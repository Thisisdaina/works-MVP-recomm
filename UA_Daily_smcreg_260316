, naver_pc AS (
    SELECT d.`Date`
        , "NB PC" campaign
        , SUM(CAST(json_extract_scalar(json_data, '$.impression') AS numeric)) Impr
        , SUM(CAST(json_extract_scalar(json_data, '$.click') AS numeric)) Click
        , CAST(20000 as numeric) as Cost
    FROM day_db d

    LEFT JOIN  `local-now-763.ua_marketing.tb_naver` a
    ON d.`Date` = FORMAT_DATE('%Y-%m-%d', PARSE_DATE('%Y.%m.%d.', json_extract_scalar(a.json_data, '$.date')))

    WHERE json_extract_scalar(json_data, '$.mediaType') = 'PC'
    GROUP BY 1, 2
)


, dv360_ajd AS (
 SELECT a.createdate
      , SUM(cast(b.Impr as numeric)) Impr
      , SUM(cast(b.Cost as numeric)) as Cost
      , SUM(cast(b.Click as numeric)) as Click
      , SUM(cast(a.daus as numeric)) daus
      , SUM(cast(a.waus as numeric)) waus
      , SUM(cast(a.maus as numeric)) maus
      , SUM(cast(a.installs as numeric)) installs
      , SUM(cast(a.ctb_clk_t_events as numeric) + cast(a.purchased_common as numeric)) as Contact
      , SUM(cast(a.smc1 as numeric) + cast(a.smc2 as numeric)) AS DB
 FROM (
          SELECT JSON_EXTRACT_SCALAR(json_data, '$.day') createdate
              , AVG(CAST(json_extract_scalar(json_data, '$.daus') AS NUMERIC)) daus
              , AVG(CAST(json_extract_scalar(json_data, '$.waus') AS NUMERIC)) waus
              , AVG(CAST(json_extract_scalar(json_data, '$.maus')  AS NUMERIC))maus
              , SUM(CAST(json_extract_scalar(json_data, '$.installs')  AS NUMERIC))installs
              , SUM(CAST(json_extract_scalar(json_data, '$.car_list_search_events')  AS NUMERIC)) cls_event
              , SUM(CAST(json_extract_scalar(json_data, '$.car_detail_view_events')  AS NUMERIC)) cdvw_events
              , SUM(CAST(json_extract_scalar(json_data, '$.purchased_car_detail_callbtn_click_events')  AS NUMERIC))ctb_events
              , SUM(CAST(json_extract_scalar(json_data, '$.pur_car_call_clk_t_events') AS NUMERIC)) ctb_clk_t_events
              , SUM(CAST(json_extract_scalar(json_data, '$.purchased_common_contact_ask_complete_events') AS NUMERIC)) purchased_common
              , SUM(CAST(json_extract_scalar(json_data, "$['smc_regist_complete (total)_events']") AS NUMERIC)) 
                + SUM(CAST(json_extract_scalar(json_data, "$['smc_reg_complete (total)_events']") AS NUMERIC)) smc1
              , SUM(CAST(json_extract_scalar(json_data, "$['smc_re-reg_complete (total)_events']") AS NUMERIC)) smc2
          FROM `local-now-763.ua_marketing.tb_adjust`
          WHERE 1=1
            AND JSON_EXTRACT_SCALAR(json_data, '$.channel') = 'Google Marketing Platform'
            AND JSON_EXTRACT_SCALAR(json_data, '$.network') = 'Display & Video 360'
            AND JSON_EXTRACT_SCALAR(json_data, '$.campaign') IN ('Display (1020348180)',
                    'Display (1020451401)', 'Display (1020674953)', 'unknown')
            AND JSON_EXTRACT_SCALAR(json_data, '$.adgroup') IN ('[Amplitude] AOS_90days (22417816950)',
                    'App Open 30days_No CDV&Try&CTB (22324682625)', 'App Open 30days_No CTB (22334861749)',
                    '[Amplitude] AOS_90days (22417808571)', 'App Open 30days_No CDV&Try&CTB (22354719503)',
                    'App Open 30days_No CTB (22348360503)', 'App Open 30days_No CDV&Try&CTB (22331177462)',
                    'App Open 30days_No CTB (22331178386)', 'unknown')
            AND JSON_EXTRACT_SCALAR(json_data, '$.creative') IN ('645608399','645608798','645640992','647531380',
                    '647531675','647563397','647533379','645647690','unknown')
            AND JSON_EXTRACT_SCALAR(json_data, '$.day') >= '2025-03-19' -- 25/3/19부터 광고시작
          GROUP BY 1
          ) a

     LEFT JOIN (
              SELECT CAST(Date AS STRING) createdate
                  , SUM( SAFE_CAST ( REGEXP_REPLACE(Revenue__Adv_Currency_, r'[₩,-]', '') AS INT64)) Cost
                  , SUM(Impressions) Impr
                  , SUM(Clicks) Click
                  
              FROM `local-now-763.ua_marketing.tb_dv360`

              GROUP BY 1
              ) b
  
     ON a.createdate = b.createdate

     GROUP BY 1
     ORDER BY 1
)



