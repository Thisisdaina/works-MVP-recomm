WITH day_db AS (
    SELECT DISTINCT CAST(day as string) `Date`
    FROM( SELECT day FROM UNNEST(GENERATE_DATE_ARRAY('2025-01-01', CURRENT_DATE()-1, INTERVAL 1 DAY)) AS day)
)

, googld_ads_adj AS (
 SELECT CASE WHEN a.`Date` IS NOT NULL THEN a.`Date` ELSE b.`Date` END `Date`
      , CASE WHEN a.campaign IS NOT NULL THEN a.campaign ELSE b.Campaign END campaign
      , SUM(cast(b.Impr as numeric)) Impr
      , SUM(cast(b.Cost as numeric)) as Cost
      , SUM(cast(b.Click as numeric)) as Click
      , SUM(cast(a.daus as numeric)) daus
      , SUM(cast(a.waus as numeric)) waus
      , SUM(cast(a.maus as numeric)) maus
      , SUM(cast(a.installs as numeric)) installs
      , SUM(cast(a.ctb_clk_t_events as numeric) + cast(a.purchased_common as numeric)) as Contact
      , SUM(cast(a.smc1 as numeric) + cast(a.smc2 as numeric)) AS DB
 FROM (
          SELECT json_extract_scalar(json_data, '$.day') `Date`
                , REGEXP_REPLACE(json_extract_scalar(json_data, '$.campaign'), r' \(\d+\)$', '') campaign
                , REGEXP_REPLACE(json_extract_scalar(json_data, '$.adgroup'), r' \(\d+\)$', '') adgroup
                , CASE WHEN json_extract_scalar(json_data, '$.creative_network') IN ('Search GoogleSearch', 'GoogleSearch') THEN 'Google 검색'
                    WHEN json_extract_scalar(json_data, '$.creative_network') IN ('Search SearchPartners','SearchPartners') THEN '검색 파트너'
                    WHEN json_extract_scalar(json_data, '$.creative_network') = 'Display' THEN 'Google 디스플레이 네트워크'
                    WHEN json_extract_scalar(json_data, '$.creative_network') IN ('Youtube YouTubeVideos', 'YouTubeVideos') THEN 'YouTube' ELSE NULL END ads_creative
                , SUM(cast(json_extract_scalar(json_data, '$.daus') as numeric)) daus
                , SUM(cast(json_extract_scalar(json_data, '$.waus') as numeric)) waus
                , SUM(cast(json_extract_scalar(json_data, '$.maus') as numeric)) maus
                , SUM(cast(json_extract_scalar(json_data, '$.installs') as numeric)) installs
                , SUM(cast(json_extract_scalar(json_data, '$.car_list_search_events') as numeric)) cls_event
                , SUM(cast(json_extract_scalar(json_data, '$.car_detail_view_events') as numeric)) cdvw_events
                , SUM(cast(json_extract_scalar(json_data, '$.purchased_car_detail_callbtn_click_events') as numeric)) ctb_events
                , SUM(cast(json_extract_scalar(json_data, '$.pur_car_call_clk_t_events') as numeric)) ctb_clk_t_events
                , SUM(cast(json_extract_scalar(json_data, '$.purchased_common_contact_ask_complete_events') as numeric)) purchased_common
                , SUM(cast(json_extract_scalar(json_data, "$['smc_reg_complete (total)_events']") as numeric)) smc1
                , SUM(cast(json_extract_scalar(json_data, "$['smc_re-reg_complete (total)_events']") as numeric)) smc2
          FROM `local-now-763.ua_marketing.tb_adjust`
          WHERE 1=1
          AND json_extract_scalar(json_data, '$.channel') = 'Google Ads'
          AND json_extract_scalar(json_data, '$.campaign') IN ('chut_app_ROAS_ACI (aos) (20680341752)', 'chut_app_ROAS (aos) (20672619833)', 'chut_app_install (aos) (13461530806)')
          GROUP BY 1, 2, 3, 4
          ) a

     FULL JOIN (
              SELECT FORMAT_DATE('%Y-%m-%d', PARSE_DATE('%Y년 %m월 %d일', JSON_EXTRACT_SCALAR(json_data, '$.Day'))) `Date`
                  , JSON_EXTRACT_SCALAR(json_data, '$.Campaign') Campaign
                  , JSON_EXTRACT_SCALAR(json_data, '$.Network') Network
                  , JSON_EXTRACT_SCALAR(json_data, '$.AdGroup') AdGroup
                  , SUM(CAST(JSON_EXTRACT_SCALAR(json_data, '$.Cost') AS NUMERIC)) Cost
                  , SUM(CAST(JSON_EXTRACT_SCALAR(json_data, '$.Impressions') AS NUMERIC)) Impr
                  , SUM(CAST(JSON_EXTRACT_SCALAR(json_data, '$.Clicks') AS NUMERIC)) Click
                  
            FROM `local-now-763.ua_marketing.tb_google_ads_adgroup`
            WHERE 1=1
            AND JSON_EXTRACT_SCALAR(json_data, '$.Campaign') IN ('chut_app_ROAS_ACI (aos)', 'chut_app_ROAS (aos)', 'chut_app_install (aos)')

            GROUP BY 1, 2, 3, 4) b
  
     ON a.`Date` = b.`Date`
     AND a.campaign = b.Campaign
     AND a.ads_creative = b.Network
     AND a.adgroup = b.AdGroup

     GROUP BY 1, 2
     ORDER BY 1

)


