, naver_adj AS (
  SELECT a.`Date`
       , CAST(b.impression AS numeric) impression
       , CAST(b.Click AS numeric) as Click
       , CAST(CASE WHEN a.`Date` <= '2025-01-14' THEN 56667 ELSE 26667 END AS NUMERIC) as Cost
       , CAST(a.installs AS numeric) installs
       , CAST(a.daus AS numeric) daus
       , CAST(a.waus AS numeric) waus
       , CAST(a.maus AS numeric)maus
       , CAST(a.Contact  AS numeric) as Contact
       , CAST(a.DB AS numeric) as DB
  FROM (SELECT CAST(json_extract_scalar(json_data, '$.day')AS STRING) `Date`
            , SUM(CAST(json_extract_scalar(json_data, '$.installs') AS NUMERIC)) installs
