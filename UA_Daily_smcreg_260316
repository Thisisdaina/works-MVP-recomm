        , SUM(CAST(json_extract_scalar(json_data, '$.pur_car_call_clk_t_events') AS NUMERIC)) +
          SUM(CAST(json_extract_scalar(json_data, '$.purchased_common_contact_ask_complete_events') AS NUMERIC)) AS Contact
