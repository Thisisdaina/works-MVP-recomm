            , SUM(CAST(json_extract_scalar(json_data, "$['smc_regist_complete (total)_events']") AS NUMERIC)) +
              SUM(CAST(json_extract_scalar(json_data, "$['smc_reg_complete (total)_events']") AS NUMERIC)) +
              SUM(CAST(json_extract_scalar(json_data, "$['smc_re-reg_complete (total)_events']") AS NUMERIC)) AS DB

        FROM `local-now-763.ua_marketing.tb_adjust`

        WHERE json_extract_scalar(json_data, '$.channel') = 'Naver_SA_Brand'
        GROUP BY 1) a

  LEFT JOIN (
              SELECT FORMAT_DATE('%Y-%m-%d', PARSE_DATE('%Y.%m.%d.', json_extract_scalar(json_data, '$.date'))) `Date`
