, naver_month AS (
    SELECT a.`Month`
        , Impr
        , Click
        , Cost
        , cnt_day
    FROM (
        SELECT FORMAT_DATE('%Y-%m', TIMESTAMP(PARSE_DATE('%Y.%m.%d.', json_extract_scalar(json_data, '$.date')))) `Month`
            , SUM(CAST(json_extract_scalar(json_data, '$.impression') AS FLOAT64)) Impr
            , SUM(CAST(json_extract_scalar(json_data, '$.click') AS FLOAT64)) Click
        FROM `local-now-763.ua_marketing.tb_naver`

        WHERE 1=1
        AND json_extract_scalar(json_data, '$.campaign_name') = '1.BS_M'

        GROUP BY 1) a

    LEFT JOIN (
            SELECT FORMAT_DATE('%Y-%m', TIMESTAMP(day)) `Month`
                , SUM(CAST(CASE WHEN day <= '2025-01-14' THEN 56667 ELSE 26667 END AS NUMERIC)) as Cost
                , COUNT(DISTINCT day) cnt_day
            FROM( SELECT day FROM UNNEST(GENERATE_DATE_ARRAY('2024-12-30', CURRENT_DATE(), INTERVAL 1 DAY)) AS day)
            GROUP BY 1) b
    ON a.`Month` = b.`Month`
)



